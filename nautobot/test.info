python -c "
import requests, urllib3, json
urllib3.disable_warnings()
token = 'paste-your-actual-40-char-token-here'
url   = 'https://yournautobot.com:8443'
headers = {'Authorization': 'Token ' + token, 'Accept': 'application/json'}
r = requests.get(url + '/api/dcim/devices/?limit=1', headers=headers, verify=False, timeout=15)
print(r.status_code)
print(json.dumps(r.json(), indent=2))
"
